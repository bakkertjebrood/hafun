generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Multi-tenancy: every table has marinaId
// ──────────────────────────────────────────

model Marina {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  settings         Json?
  subscriptionPlan String?
  gpsLat           Float?
  gpsLng           Float?
  setupComplete    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users          User[]
  berths         Berth[]
  customers      Customer[]
  boats          Boat[]
  bookings       Booking[]
  guests         Guest[]
  invoices       Invoice[]
  notes          Note[]
  pierLines      PierLine[]
  tariffs        Tariff[]
  facilities     Facility[]
  accounting     AccountingIntegration?
  waitlist       WaitlistEntry[]
  agendaEvents   AgendaEvent[]
  quotes         Quote[]
  workOrders     WorkOrder[]
  meterReadings  MeterReading[]
  auditLogs      AuditLog[]
  posProducts    PosProduct[]
  posTransactions PosTransaction[]
  payments       Payment[]
}

// Pier geometry — drawn on the map
// points: [[lat,lng], ...] main spine of the pier
// headPoints: [[lat,lng], ...] optional T-head (perpendicular kopzijde)
// berthOffset: perpendicular distance (meters) from the spine to a berth's center
model PierLine {
  id          String   @id @default(uuid())
  marinaId    String
  name        String   // "A", "B", "C" etc.
  points      Json?    // [[lat,lng], [lat,lng], ...] main line (null until drawn on map)
  headPoints  Json?    // [[lat,lng], [lat,lng]] T-head kopzijde
  berthOffset Float    @default(3.5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])

  @@unique([marinaId, name])
  @@index([marinaId])
}

// Physical facilities / points of interest drawn on the marina map
// (toilets, canteen, parking, crane, fuel dock, etc.)
enum FacilityType {
  SANITAIR
  KANTINE
  PARKEREN
  HAVENMEESTER
  TANKSTATION
  AFVAL
  KRAAN
  WERKPLAATS
  WINKEL
  TERRAS
  SPEELTUIN
  WATERPUNT
  STROOMPUNT
  WIFI
  EHBO
  HELLING
  TOEGANG
  OVERIG
}

model Facility {
  id          String       @id @default(uuid())
  marinaId    String
  type        FacilityType
  name        String?
  description String?
  gpsLat      Float
  gpsLng      Float
  radius      Float?       // optional visual radius in meters for larger areas (parking, terrace)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])

  @@index([marinaId])
}

enum Role {
  ADMIN
  HARBORMASTER
  STAFF
  PORTAL
}

model User {
  id           String   @id @default(uuid())
  marinaId     String
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  avatar       String?
  role         Role     @default(STAFF)
  firstName    String?
  lastName     String?
  locale       String   @default("nl")   // nl, en, fr, de, sv
  emailFooter  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marina      Marina        @relation(fields: [marinaId], references: [id])
  notes       Note[]
  customer    Customer?
  auditLogs   AuditLog[]
  agendaEvents AgendaEvent[]
  workOrders  WorkOrder[]   @relation("WorkOrderAssignee")

  @@index([marinaId])
}

enum BerthStatus {
  FREE
  OCCUPIED
  TEMPORARY
  STORAGE
  SEASONAL
  EMPTY
  RELOCATED
}

model Berth {
  id           String      @id @default(uuid())
  marinaId     String
  code         String
  pier         String
  length       Float
  width        Float
  status       BerthStatus @default(FREE)
  isPassanten  Boolean     @default(false)
  gpsLat       Float?
  gpsLng       Float?
  side         String?     // "LEFT" | "RIGHT" | "HEAD" | null
  customerId   String?
  boatId       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  marina   Marina    @relation(fields: [marinaId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  boat     Boat?     @relation(fields: [boatId], references: [id])
  notes    Note[]
  bookings Booking[]
  meterReadings MeterReading[]
  workOrders WorkOrder[]

  @@index([marinaId])
  @@index([marinaId, pier])
}

enum ContractType {
  YEAR
  SUMMER
  TEMPORARY
}

model Customer {
  id           String       @id @default(uuid())
  marinaId     String
  name         String
  email        String?
  phone        String?
  address      String?
  contractType ContractType @default(YEAR)
  portalUserId String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  marina     Marina    @relation(fields: [marinaId], references: [id])
  portalUser User?     @relation(fields: [portalUserId], references: [id])
  boats      Boat[]
  berths     Berth[]
  bookings   Booking[]
  invoices   Invoice[]
  quotes     Quote[]
  workOrders WorkOrder[]
  meterReadings MeterReading[]

  @@index([marinaId])
}

model Boat {
  id           String   @id @default(uuid())
  marinaId     String
  customerId   String?
  name         String
  type         String?
  length       Float
  width        Float?
  registration String?
  photo        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marina     Marina    @relation(fields: [marinaId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  berths     Berth[]
  bookings   Booking[]
  workOrders WorkOrder[]

  @@index([marinaId])
}

model Booking {
  id         String   @id @default(uuid())
  marinaId   String
  berthId    String
  customerId String?
  guestId    String?
  boatId     String?
  dateFrom   DateTime
  dateTo     DateTime
  status     String   @default("reserved")
  persons    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  marina   Marina    @relation(fields: [marinaId], references: [id])
  berth    Berth     @relation(fields: [berthId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  guest    Guest?    @relation(fields: [guestId], references: [id])
  boat     Boat?     @relation(fields: [boatId], references: [id])

  @@index([marinaId])
  @@index([marinaId, berthId])
}

model Guest {
  id         String    @id @default(uuid())
  marinaId   String
  name       String
  boatName   String?
  boatLength Float?
  arrival    DateTime
  departure  DateTime?
  persons    Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  marina   Marina    @relation(fields: [marinaId], references: [id])
  bookings Booking[]

  @@index([marinaId])
}

// Accounting integration config per marina (Moneybird, Exact, etc.)
model AccountingIntegration {
  id               String  @id @default(uuid())
  marinaId         String  @unique
  provider         String  // "moneybird", "exact", "visma"
  apiToken         String
  administrationId String?
  settings         Json?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])
}

// Light invoice reference — points to external accounting system
model Invoice {
  id            String   @id @default(uuid())
  marinaId      String
  customerId    String?
  externalId    String?  // ID in external system (Moneybird invoice ID)
  externalUrl   String?  // Direct link to invoice in external system
  paymentUrl    String?  // Public payment link
  number        String?
  description   String?  // "Jaarplaats A01 — 2026"
  total         Float
  paidAmount    Float    @default(0)
  status        String   @default("draft") // draft, sent, paid, overdue
  dueDate       DateTime?
  reminderCount Int      @default(0)
  lastReminder  DateTime?
  syncedAt      DateTime? // last sync with external system
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  marina   Marina    @relation(fields: [marinaId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  payments Payment[]

  @@unique([marinaId, number])
  @@index([marinaId])
}

// Deelbetalingen op een factuur
model Payment {
  id         String   @id @default(uuid())
  marinaId   String
  invoiceId  String
  amount     Float
  method     String   // cash, pin, transfer, creditcard, online
  reference  String?
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  marina  Marina  @relation(fields: [marinaId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([marinaId])
  @@index([invoiceId])
}

model Note {
  id         String   @id @default(uuid())
  marinaId   String
  berthId    String?
  customerId String?
  text       String
  authorId   String
  createdAt  DateTime @default(now())

  marina Marina @relation(fields: [marinaId], references: [id])
  berth  Berth? @relation(fields: [berthId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([marinaId])
  @@index([berthId])
}

enum TariffType {
  YEAR
  SUMMER
  WINTER
  GUEST
  PASSANT
}

model Tariff {
  id          String     @id @default(uuid())
  marinaId    String
  name        String     // "Jaarplaats", "Seizoenplaats", "Passant per nacht"
  type        TariffType
  pricePerMeter Float    // prijs per strekkende meter
  minLength   Float?     // minimum bootlengte
  maxLength   Float?     // maximum bootlengte
  vatRate     Float      @default(21)
  touristTax  Float      @default(0) // toeristenbelasting per persoon per nacht
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])

  @@index([marinaId])
}

// Wachtlijst voor ligplaatsen
model WaitlistEntry {
  id          String   @id @default(uuid())
  marinaId    String
  name        String
  email       String?
  phone       String?
  boatLength  Float?
  boatWidth   Float?
  boatType    String?
  preferredPier String?
  notes       String?
  priority    Int      @default(0)
  status      String   @default("waiting") // waiting, offered, accepted, rejected, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])

  @@index([marinaId])
}

// Agenda / kalender
enum AgendaEventType {
  MEETING
  MAINTENANCE
  EVENT
  REMINDER
  ARRIVAL
  DEPARTURE
  OTHER
}

model AgendaEvent {
  id          String          @id @default(uuid())
  marinaId    String
  title       String
  description String?
  type        AgendaEventType @default(OTHER)
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean         @default(false)
  location    String?
  authorId    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([marinaId])
  @@index([marinaId, startAt])
}

// Offertes
model Quote {
  id          String   @id @default(uuid())
  marinaId    String
  customerId  String?
  number      String?
  title       String
  description String?
  lines       Json     // [{description, quantity, unitPrice, vatRate}]
  total       Float
  status      String   @default("draft") // draft, sent, accepted, rejected, expired
  validUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  marina   Marina    @relation(fields: [marinaId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([marinaId])
}

// Werkbonnen
model WorkOrder {
  id          String   @id @default(uuid())
  marinaId    String
  customerId  String?
  boatId      String?
  berthId     String?
  number      String?
  title       String
  description String?
  priority    String   @default("normal") // low, normal, high, urgent
  status      String   @default("open")   // open, in_progress, done, invoiced, cancelled
  assigneeId  String?
  lines       Json?    // [{description, quantity, unitPrice, vatRate}]
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  marina   Marina    @relation(fields: [marinaId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  boat     Boat?     @relation(fields: [boatId], references: [id])
  berth    Berth?    @relation(fields: [berthId], references: [id])
  assignee User?     @relation("WorkOrderAssignee", fields: [assigneeId], references: [id])

  @@index([marinaId])
}

// Standen-log (stroom / water meterstanden per ligplaats)
enum MeterType {
  ELECTRICITY
  WATER
  GAS
}

model MeterReading {
  id        String    @id @default(uuid())
  marinaId  String
  berthId   String?
  customerId String?
  type      MeterType
  value     Float
  readAt    DateTime  @default(now())
  note      String?
  authorId  String?
  createdAt DateTime  @default(now())

  marina   Marina    @relation(fields: [marinaId], references: [id])
  berth    Berth?    @relation(fields: [berthId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([marinaId])
  @@index([berthId])
}

// Mutatielog / audit-log
model AuditLog {
  id         String   @id @default(uuid())
  marinaId   String
  userId     String?
  entity     String   // "Customer", "Berth", "Invoice", ...
  entityId   String?
  action     String   // "create", "update", "delete", "login", ...
  diff       Json?    // {before, after} of {field: value}
  createdAt  DateTime @default(now())

  marina Marina @relation(fields: [marinaId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([marinaId])
  @@index([marinaId, entity])
}

// Kassa / POS — producten
model PosProduct {
  id         String   @id @default(uuid())
  marinaId   String
  name       String
  category   String?  // "drank", "ijs", "technisch", ...
  price      Float
  vatRate    Float    @default(21)
  stock      Int?
  barcode    String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  marina Marina @relation(fields: [marinaId], references: [id])

  @@index([marinaId])
}

// Kassa / POS — transacties
model PosTransaction {
  id         String   @id @default(uuid())
  marinaId   String
  cashierId  String?
  customerId String?
  lines      Json     // [{productId, name, quantity, unitPrice, vatRate}]
  subtotal   Float
  vatAmount  Float
  total      Float
  method     String   // cash, pin, creditcard, invoice, online
  note       String?
  createdAt  DateTime @default(now())

  marina Marina @relation(fields: [marinaId], references: [id])

  @@index([marinaId])
  @@index([marinaId, createdAt])
}
