# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nautar?schema=public"

# Auth — generate a long random string for production (>= 64 chars).
JWT_SECRET="change-this-to-a-secure-random-string"

# App URL (used as the base for OAuth redirect URIs and email links).
# In production: https://your-app.herokuapp.com or your custom domain.
APP_URL="http://localhost:3000"

# Google OAuth — leave empty to disable Google login.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Postmark transactional email
POSTMARK_API_KEY=""
EMAIL_FROM="no-reply@nautar.app"

# Anthropic (used for AI berth/facility detection — optional)
CLAUDE_API_KEY=""
